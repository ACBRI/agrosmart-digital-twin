# AgroSmart Digital Twin - Configuration
# Copy to .env and adjust as needed.

# --- External ports (isolated range, not standard) ---
AGROSMART_GRAFANA_PORT=3333
AGROSMART_MQTT_PORT=18830
AGROSMART_MQTT_WS_PORT=18831
AGROSMART_DB_PORT=54329
AGROSMART_WEB_PORT=8095
AGROSMART_WEATHER_PORT=8096
AGROSMART_PREDICTOR_PORT=8097

# --- Database ---
AGROSMART_DB_USER=agrosmart
AGROSMART_DB_PASSWORD=agrosmart_local_dev
AGROSMART_DB_NAME=agrosmart

# --- Grafana ---
AGROSMART_GRAFANA_USER=admin
AGROSMART_GRAFANA_PASSWORD=admin

# --- Simulation ---
# Time acceleration: 1 real second = N simulated seconds.
# 60 => one simulated minute per real second (a full day in 24 real minutes).
AGROSMART_TIME_SCALE=60

# Telemetry cadence in SIMULATED seconds (field nodes wake every 15 min).
AGROSMART_TELEMETRY_INTERVAL_S=900

# Irrigation thresholds (percent of field capacity).
AGROSMART_MOISTURE_LOW=35
AGROSMART_MOISTURE_TARGET=70
